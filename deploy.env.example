# ============================================
# 部署环境变量配置
# ============================================
# ⚠️ 复制此文件为 deploy.env 并填入真实值
# ⚠️ 请勿将 deploy.env 提交到 Git

# ============================================
# 阿里云 ACR 配置
# ============================================
# ACR 命名空间 (需要先在阿里云控制台创建)
ACR_NAMESPACE=your-namespace

# ACR 用户名 (通常是阿里云账号全名)
ACR_USERNAME=your-username@aliyun.com

# ACR 密码 (在 ACR 控制台设置独立密码)
ACR_PASSWORD=your-acr-password

# ============================================
# ECS 配置
# ============================================
# ECS 公网 IP (在 Terraform apply 后获取)
ECS_PUBLIC_IP=xxx.xxx.xxx.xxx

# SSH 私钥路径
SSH_KEY_PATH=~/.ssh/your-key

# ============================================
# Docker 镜像配置
# ============================================
IMAGE_NAME=stem-story
IMAGE_TAG=latest

# ============================================
# 项目路径
# ============================================
# Dockerfile 所在目录的绝对路径
PROJECT_DIR=/Users/jessi/ai-project/easysteam/stem-story-generator
